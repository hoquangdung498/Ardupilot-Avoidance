<launch>
    <!-- Hardware configurations -->
    <arg name="fcu_url" default="/dev/ttyTHS1:921600"/>
    
    <!-- Topic variables -->
    <arg name="local_pointcloud_topic" default="[/camera/depth/points_downsampled]"/>
    <arg name="global_pointcloud_topic" default="[/camera/depth/points]"/>

    <!-- Define a static transform from a camera internal frame to the fcu -->
    <node pkg="tf" type="static_transform_publisher" name="tf_depth_camera"
          args="0 0 0 -1.57 0 -1.57 fcu camera_link 10"/>

    <!-- Launch MAVROS for Ardupilot -->
    <include file="$(find avoidance)/launch/avoidance_ardupilot_mavros.launch" >
        <arg name="fcu_url" value="$(arg fcu_url)" />
    </include>

    <!-- ============================================== -->
    <!-- LOCAL PLANNER SECTION                          -->
    <!-- ============================================== -->

    <arg name="manager" default="local_planner_manager"/>
    <node pkg="nodelet" type="nodelet" name="$(arg manager)" args="manager" output="screen"/>

    <!-- PointCloud Downsampling for Local Planner (CPU optimization) -->
    <node pkg="nodelet" type="nodelet" name="voxel_grid" args="load pcl/VoxelGrid $(arg manager)" output="screen">
      <remap from="~input" to="/camera/depth/points" />
      <remap from="~output" to="/camera/depth/points_downsampled" />
      <param name="filter_field_name" value="z" />
      <param name="filter_limit_min" value="0.2" />
      <param name="filter_limit_max" value="5.0" />
      <param name="filter_limit_negative" value="False" />
      <param name="leaf_size" value="0.2" />
    </node>

    <!-- Local Planner Nodelet -->
    <node pkg="nodelet" type="nodelet" name="local_planner_nodelet" args="load avoidance/LocalPlannerNodelet $(arg manager)" output="screen">
      <!-- These initial goal params are overridden if Rviz or Global Planner sends a goal -->
      <param name="goal_x_param" value="10" />
      <param name="goal_y_param" value="0"/>
      <param name="goal_z_param" value="2" />
      
      <!-- Optimization for Jetson Nano CPU -->
      <param name="children_per_node_" value="4" />
      <param name="n_expanded_nodes_" value="20" />
      <param name="smoothing_margin_degrees_" value="30" />
      <param name="min_num_points_per_cell_" value="2" />
      
      <rosparam param="pointcloud_topics" subst_value="True">$(arg local_pointcloud_topic)</rosparam>
    </node>

    <!-- ============================================== -->
    <!-- GLOBAL PLANNER SECTION                         -->
    <!-- ============================================== -->

    <!-- OctoMap Server -->
    <node pkg="octomap_server" type="octomap_server_node" name="octomap_server">
        <param name="resolution" value="1.0" />
        <param name="frame_id" type="string" value="local_origin" />
        <param name="sensor_model/max_range" value="9.0" />
        <param name="sensor_model/min" value="0.01" />
        <param name="sensor_model/max" value="0.99" />
        <param name="sensor_model/hit" value="0.9" />
        <param name="sensor_model/miss" value="0.45" />
        <param name="color/r" value="0.1" />
        <param name="color/g" value="0.1" />
        <param name="color/b" value="0.1" />
        <param name="color/a" value="1.0" />
        <param name="occupancy_min_z" value="1.0" />
        <param name="height_map" value="false" />
        <param name="publish_free_space" value="false" />
        <remap from="cloud_in" to="/camera/depth/points" />
    </node>

    <!-- Global Planner Node -->
    <node name="global_planner_node" pkg="global_planner" type="global_planner_node" output="screen">
        <param name="frame_id" type="string" value="local_origin" />
        <param name="camera_frame_id" type="string" value="camera_link" />
        <param name="start_pos_x" value="0.0" />
        <param name="start_pos_y" value="0.0" />
        <param name="start_pos_z" value="2.0" />
        
        <!-- Hierarchical Planning Setup: Output to Local Planner instead of MAVROS -->
        <param name="output_to_local_planner" value="true" />
        
        <rosparam param="pointcloud_topics" subst_value="True">$(arg global_pointcloud_topic)</rosparam>
        <param name="robot_radius" value="0.5" /> 
    </node>

    <!-- Global GPS Adapter for Mission Planning -->
    <node name="global_gps_adapter" pkg="global_planner" type="global_gps_adapter" output="screen" />

</launch>
